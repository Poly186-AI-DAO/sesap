namespace com.sesap.contract@1.0.0

@template
concept ContractData {
  o String contractId
  o DateTime effectiveDate optional
  o Party provider
  o Party intermediary optional
  o Party client
  o String[] engagementType
  o String[] scopeDeliverables
  o String[] phases
  o String timelineDuration
  o String[] milestones
  o String paymentTerms
  o String estimatedValue optional
  o String roiExpectation
  o String[] nextSteps
  o String[] keyQuotes
  o String providerSignatureName
  o String clientSignatureName
  o DateTime providerSignatureDate optional
  o DateTime clientSignatureDate optional
  o String notes optional
}

concept Party {
  o String name
  o String role
  o String contactSummary optional
  o String contactNotes optional
}
