namespace org.accord.poc

concept SmartContract {
  o String contractTitle
  o Parties parties
  o String[] engagementType
  o ScopeOfWork scopeOfWork
  o Timeline timeline
  o CommercialTerms commercialTerms
  o NextStep[] nextSteps
  o String[] nextStepsSummaries optional
  o String[] keyQuotes
  o Signature[] signatures
}

concept Parties {
  o Party provider
  o Party intermediary optional
  o Party client
}

concept Party {
  o String name
  o String role
  o Contact[] contacts optional
  o String[] contactsDisplay optional
}

concept Contact {
  o String name
  o String role optional
  o String notes optional
}

concept ScopeOfWork {
  o String[] deliverables
  o Phase[] phases
  o String[] phaseSummaries optional
}

concept Phase {
  o String name
  o String description
  o String[] activities
  o String[] dependencies optional
  o String[] outputs optional
}

concept Timeline {
  o String startDate optional
  o String duration optional
  o Milestone[] milestones
  o String[] milestonesSummaries optional
}

concept Milestone {
  o String name
  o String targetDate optional
  o String details optional
}

concept CommercialTerms {
  o String paymentTerms
  o String estimatedValue optional
  o String roiExpectation optional
}

concept NextStep {
  o String owner
  o String action
  o String status optional
  o String source optional
}

concept Signature {
  o String signerName
  o String role
  o String date optional
  o String signature optional
}
