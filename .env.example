# ============================================
# SESAP Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --------------------------------------------
# WEB3AUTH - Social Login & Wallet Creation
# Get from: https://dashboard.web3auth.io/
# --------------------------------------------
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=your_client_id_here
WEB3_AUTH_PROJECT_NAME=SESAP
WEB3_AUTH_CLIENT_ID=your_client_id_here
WEB3_AUTH_CLIENT_KEY=your_client_key_here
WEB3_AUTH_ENVIRONMENT=sapphire_devnet
WEB3_AUTH_JWKS_ENDPOINT=https://api-auth.web3auth.io/.well-known/jwks.json

# --------------------------------------------
# AI - Azure AI Foundry (for contract generation)
# --------------------------------------------
AZURE_AI_FOUNDRY_BASE_URL=your_azure_endpoint
AZURE_AI_FOUNDRY_KEY=your_azure_key
AZURE_OPEN_AI_VERSION=2025-01-01-preview

# --------------------------------------------
# DATABASE - PostgreSQL
# --------------------------------------------
POSTGRES_HOST=your_host.postgres.database.azure.com
POSTGRES_USER=your_user
POSTGRES_DB=your_database
POSTGRES_PORT=5432
POSTGRES_SSL_MODE=require
POSTGRES_PASSWORD=your_password

# --------------------------------------------
# APPLICATION
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SESAP
NODE_ENV=development
NEXTAUTH_SECRET=generate_a_random_32_char_string_here
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------
# FEATURE FLAGS
# --------------------------------------------
NEXT_PUBLIC_ENABLE_BLOCKCHAIN_MINTING=false
NEXT_PUBLIC_ENABLE_AI_GENERATION=true

# --------------------------------------------
# BLOCKCHAIN - Gnosis Chain (Phase 2 - Optional)
# --------------------------------------------
NEXT_PUBLIC_GNOSIS_RPC_URL=https://rpc.gnosischain.com
NEXT_PUBLIC_GNOSIS_CHAIN_ID=100
